# Sentinel Environment Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# DEFAULT MODEL
# =============================================================================
# Format: provider:model (e.g., ollama:llama3.3, google:gemini-2.0-flash)
# If not set, defaults to ollama:llama3.3 (free, local)
# SENTINEL_MODEL=ollama:llama3.3

# =============================================================================
# PROVIDER CREDENTIALS
# =============================================================================
# Only configure the providers you plan to use.

# --- Ollama (local, no key needed) ---
# OLLAMA_BASE_URL=http://localhost:11434

# --- Ollama (cloud-hosted) ---
# OLLAMA_BASE_URL=https://your-cloud-ollama.example.com
# OLLAMA_HEADERS=Authorization=Bearer your-token

# --- Google Gemini ---
# GOOGLE_API_KEY=your-google-api-key

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-openai-key

# --- Anthropic ---
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- OpenAI-Compatible (e.g., local server, Groq, Together) ---
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_API_KEY=your-key
# OPENAI_COMPATIBLE_MODEL=local-model

# =============================================================================
# PIPELINE SETTINGS
# =============================================================================
# PIPELINE_TESTING=true    # Minimal prompts, 10s retries for dev/test
